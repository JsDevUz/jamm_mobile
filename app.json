{
  "expo": {
    "name": "Jamm",
    "slug": "jamm-mobile",
    "scheme": "jamm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1020"
    },
    "plugins": [
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "communication",
            "enableScreenShareService": true
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      "@config-plugins/react-native-webrtc",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#5865F2"
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker"
    ],
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:jamm.uz",
        "applinks:www.jamm.uz"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Video meet uchun kamera ishlatiladi.",
        "NSMicrophoneUsageDescription": "Video meet uchun mikrofon ishlatiladi.",
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "bundleIdentifier": "com.jsdevuz.jammmobile"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0B1020",
        "foregroundImage": "./assets/logo-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "jamm.uz"
            },
            {
              "scheme": "https",
              "host": "www.jamm.uz"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "jamm"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.jsdevuz.jammmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "84e18a0d-ac93-457b-87e7-bf896ff0b791"
      }
    }
  }
}
